# =============================================================================
# Mais alvos (switch, etc.): docs/private.example/homelab/SNMP_LAB_TARGETS.pt_BR.md
# Copie para:  docs/private/homelab/.env.snmp.local
# (caminho gitignored — não faça commit de valores reais)
#
# Definir $env:... no PowerShell NÃO cria este arquivo — copie este modelo manualmente.
#
# Regras: uma linha por variável, formato KEY=value, SEM espaços em volta do "=".
# Linhas que começam com # são ignoradas.
# =============================================================================
#
# O que é cada variável (SNMPv3 authPriv, alinhado a scripts/snmp-udm-lab-probe.ps1):
#
# LAB_UDM_SNMP_HOST     → IP de gestão do gateway/UDM na LAN (o mesmo host onde o SNMP está ativo).
# LAB_UDM_SNMP_V3_USER  → Nome de usuário SNMPv3 configurado no equipamento (ex.: UniFi).
# LAB_UDM_SNMP_AUTH_PASS → Senha de autenticação (protocolo SHA no script).
# LAB_UDM_SNMP_PRIV_PASS → Senha de privacidade / criptografia (AES no script).
#
# Valores abaixo são SINTÉTICOS — substitua pelos seus antes de usar.
# =============================================================================

LAB_UDM_SNMP_HOST=192.0.2.10
LAB_UDM_SNMP_V3_USER=oper_snmp_lab
LAB_UDM_SNMP_AUTH_PASS=Syn_Auth_7kQm9pL2vN4wR8xT1
LAB_UDM_SNMP_PRIV_PASS=Syn_Priv_3mK8nQ5wZ2cV6hJ0
